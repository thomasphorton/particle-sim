{
  "name": "particle-sim",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "vite",
    "typecheck:shared": "tsc -p packages/shared/tsconfig.json --pretty false --noEmit",
    "typecheck:client": "tsc -p tsconfig.json --pretty false",
    "typecheck": "npm run typecheck:shared && npm run typecheck:client",
    "build:shared": "npm --workspace @particle-sim/shared run build",
    "build:client": "tsc -p tsconfig.json --pretty false && vite build",
    "build": "npm run build:shared && npm run build:client",
    "test:shared": "npm --workspace @particle-sim/shared run test:smoke",
    "test:client": "vitest run",
    "test": "npm run build:shared && npm run test:client && npm run test:shared",
    "preview": "vite preview",
    "benchmark": "node ./scripts/benchmark-shared.mjs"
  },
  "dependencies": {
    "@particle-sim/shared": "0.0.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.10",
    "jsdom": "^29.1.1",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.10"
  }
}
